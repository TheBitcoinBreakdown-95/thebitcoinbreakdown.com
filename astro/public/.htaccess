# Redirects from old WordPress URLs to new Astro URLs
# WordPress pattern: /{year}/{month}/{day}/{slug}/
# Astro pattern: /blog/{year}/{slug}/

RewriteEngine On

# WordPress blog posts → Astro blog posts
# Matches /{year}/{month}/{day}/{slug}/ and redirects to /blog/{year}/{slug}/
RewriteRule ^(\d{4})/\d{2}/\d{2}/(.+?)/?$ /blog/$1/$2/ [R=301,L]

# WordPress category pages → blog listing
RewriteRule ^category/(.+)/?$ /blog/ [R=301,L]

# WordPress tag pages → blog listing
RewriteRule ^tag/(.+)/?$ /blog/ [R=301,L]

# WordPress feed → RSS
RewriteRule ^feed/?$ /rss.xml [R=301,L]

# WordPress wp-content uploads (images still at same paths)
# No redirect needed — images are at /images/ now

# Blog posts moved to guide (Chapter 1 — What is Bitcoin?)
RewriteRule ^blog/2023/intro/?$ /guide/intro/ [R=301,L]
RewriteRule ^blog/2023/what-is-bitcoin-2/?$ /guide/what-is-bitcoin-2/ [R=301,L]
RewriteRule ^blog/2023/bitcoin-is-digital-gold/?$ /guide/bitcoin-is-digital-gold/ [R=301,L]
RewriteRule ^blog/2023/the-great-excel-spreadsheet-in-the-sky/?$ /guide/the-great-excel-spreadsheet-in-the-sky/ [R=301,L]
RewriteRule ^blog/2023/bitcoin-is-information/?$ /guide/bitcoin-is-information/ [R=301,L]
RewriteRule ^blog/2023/what-is-bitcoin-3/?$ /guide/what-is-bitcoin-3/ [R=301,L]
RewriteRule ^blog/2023/bitcoin-is-a-network/?$ /guide/bitcoin-is-a-network/ [R=301,L]
RewriteRule ^blog/2023/bitcoin-is-time/?$ /guide/bitcoin-is-time/ [R=301,L]
RewriteRule ^blog/2023/bitcoin-is-money/?$ /guide/bitcoin-is-money/ [R=301,L]
RewriteRule ^blog/2023/bitcoin-is-the-internet-of-money/?$ /guide/bitcoin-is-the-internet-of-money/ [R=301,L]
RewriteRule ^blog/2023/other-peoples-bitcoin-definitions/?$ /guide/other-peoples-bitcoin-definitions/ [R=301,L]

# Blog posts moved to guide (Chapter 2 — Why Bitcoin?)
RewriteRule ^blog/2023/why-should-you-care/?$ /guide/why-should-you-care/ [R=301,L]
RewriteRule ^blog/2023/bitcoin-will-save-the-world/?$ /guide/bitcoin-will-save-the-world/ [R=301,L]
RewriteRule ^blog/2023/why-was-bitcoin-invented/?$ /guide/why-was-bitcoin-invented/ [R=301,L]
RewriteRule ^blog/2023/why-will-bitcoin-win/?$ /guide/why-will-bitcoin-win/ [R=301,L]
RewriteRule ^blog/2022/absolute-scarcity/?$ /guide/absolute-scarcity/ [R=301,L]
RewriteRule ^blog/2022/the-trust-machine/?$ /guide/the-trust-machine/ [R=301,L]
RewriteRule ^blog/2023/they-invented-a-better-money-who-does-that/?$ /guide/they-invented-a-better-money-who-does-that/ [R=301,L]
RewriteRule ^blog/2023/unparalleled-new/?$ /guide/unparalleled-new/ [R=301,L]
# Guide → Blog (reclassified as speech)
RewriteRule ^guide/orange-not-gold/?$ /blog/2023/orange-not-gold/ [R=301,L]

# Blog → Guide (reclassified as compendium 4.2)
RewriteRule ^blog/2022/the-mystery-of-satoshi-nakamoto/?$ /guide/the-mystery-of-satoshi-nakamoto/ [R=301,L]

# Deleted overview chapters → chapter landing pages
RewriteRule ^guide/what-is-bitcoin/?$ /guide/chapter/1 [R=301,L]
RewriteRule ^guide/why-bitcoin/?$ /guide/chapter/2 [R=301,L]
RewriteRule ^guide/problems-bitcoin-solves/?$ /guide/chapter/3 [R=301,L]
RewriteRule ^guide/bitcoin-past/?$ /guide/chapter/4 [R=301,L]
RewriteRule ^guide/bitcoin-properties/?$ /guide/chapter/5 [R=301,L]
RewriteRule ^guide/what-is-bitcoin-exactly/?$ /guide/chapter/6 [R=301,L]
RewriteRule ^guide/bitcoin-present/?$ /guide/chapter/7 [R=301,L]
RewriteRule ^guide/why-bitcoin-is-good-af/?$ /guide/chapter/8 [R=301,L]
RewriteRule ^guide/bitcoin-future/?$ /guide/chapter/9 [R=301,L]

# Custom 404
ErrorDocument 404 /404.html
