---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const sortedGuides = allGuides.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Guides" description="Step-by-step Bitcoin and Lightning guides -- from wallet setup to running your own node.">
  <section class="blog-page section">
    <div class="container--wide">
      <header class="page-header reveal">
        <h1>Guides</h1>
        <p class="section-desc">Step-by-step technical guides. Copy-paste code, real commands, tested instructions.</p>
      </header>

      {sortedGuides.length > 0 ? (
        <div class="card-grid stagger">
          {sortedGuides.map((post) => (
            <div class="reveal">
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                slug={post.id}
                tags={post.data.tags}
                image={post.data.image}
                basePath="/guides"
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <div class="empty-icon">&#9881;</div>
          <h3 class="empty-title">No guides yet</h3>
          <p class="empty-desc">Guides are on the way. Check back soon.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-6);
  }

  .page-header h1 {
    margin-bottom: var(--space-3);
  }
</style>
