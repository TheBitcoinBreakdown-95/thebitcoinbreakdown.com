---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Divider from '../../components/Divider.astro';
import { chapters } from '../../data/chapters';

export async function getStaticPaths() {
  const guide = await getCollection('guide');
  return guide.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Calculate reading time
const wordCount = entry.body ? entry.body.split(/\s+/).length : 0;
const minutes = Math.ceil(wordCount / 200);
const readingTime = minutes <= 1 ? '1 min read' : `${minutes} min read`;

// Get all guide entries for navigation
const allGuide = await getCollection('guide', ({ data }) => !data.draft);

// Sort all entries by (chapter, order) for linear prev/next navigation
const sortedGuide = [...allGuide].sort((a, b) => {
  if (a.data.chapter !== b.data.chapter) return a.data.chapter - b.data.chapter;
  return (a.data.order || 1) - (b.data.order || 1);
});
const currentIndex = sortedGuide.findIndex(g => g.id === entry.id);
const prevEntry = currentIndex > 0 ? sortedGuide[currentIndex - 1] : null;
const nextEntry = currentIndex < sortedGuide.length - 1 ? sortedGuide[currentIndex + 1] : null;

// Get siblings (same chapter) for sub-chapter navigation
const siblings = allGuide
  .filter(g => g.data.chapter === entry.data.chapter)
  .sort((a, b) => (a.data.order || 1) - (b.data.order || 1));
const showSiblingNav = siblings.length > 1;

// Chapter metadata
const chapterMeta = chapters.find(c => c.num === entry.data.chapter);

// Format chapter label
function chapterLabel(e: typeof entry) {
  const ch = e.data.chapter;
  const ord = e.data.order || 1;
  return `Ch. ${ch}.${ord - 1}`;
}
function chapterHeading(e: typeof entry) {
  const ch = e.data.chapter;
  const ord = e.data.order || 1;
  return `Chapter ${ch}.${ord - 1}`;
}

// Build TOC from headings (3+ required)
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 3;

---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="guide-article section">
    <div class="container">
      <header class="guide-header reveal">
        <div class="guide-chapter-label">
          {chapterHeading(entry)}
        </div>
        <h1 data-type>{entry.data.title}</h1>
        <p class="guide-description">{entry.data.description}</p>
        <div class="guide-meta">
          <span>{readingTime}</span>
        </div>
      </header>

      <div class="post-content prose">
        {showToc && (
          <nav class="toc" aria-label="Table of contents">
            <details open>
              <summary class="toc-title">Contents</summary>
              <ul class="toc-list">
                {tocHeadings.map((h) => (
                  <li class:list={[`toc-depth-${h.depth}`]}>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ul>
            </details>
          </nav>
        )}

        {showSiblingNav && chapterMeta && (
          <nav class="chapter-nav" aria-label="Chapter sub-chapters">
            <div class="chapter-nav-title">
              <a href={`/guide/chapter/${entry.data.chapter}`} class="chapter-nav-link tbb-link">
                Chapter {entry.data.chapter} &mdash; {chapterMeta.title}
              </a>
            </div>
            <ul class="chapter-nav-list">
              {siblings.map((sib) => {
                const isCurrent = sib.id === entry.id;
                const sibNum = `${sib.data.chapter}.${(sib.data.order || 1) - 1}`;
                return (
                  <li class:list={[{ 'chapter-nav-current': isCurrent }]}>
                    {isCurrent ? (
                      <span class="chapter-nav-item">
                        <span class="chapter-nav-num">{sibNum}</span>
                        {sib.data.title}
                      </span>
                    ) : (
                      <a href={`/guide/${sib.id}`} class="chapter-nav-item tbb-link">
                        <span class="chapter-nav-num">{sibNum}</span>
                        {sib.data.title}
                      </a>
                    )}
                  </li>
                );
              })}
            </ul>
          </nav>
        )}

        <Content />
      </div>

      <Divider />

      <nav class="guide-nav reveal" aria-label="Chapter navigation">
        <div class="guide-nav-inner">
          {prevEntry ? (
            <a href={`/guide/${prevEntry.id}`} class="guide-nav-link guide-nav-prev tbb-link">
              <span class="guide-nav-label">&larr; Previous</span>
              <span class="guide-nav-title">{chapterLabel(prevEntry)}: {prevEntry.data.title}</span>
            </a>
          ) : (
            <a href={`/guide/chapter/${entry.data.chapter}`} class="guide-nav-link guide-nav-prev tbb-link">
              <span class="guide-nav-label">&larr; Back</span>
              <span class="guide-nav-title">Chapter {entry.data.chapter}</span>
            </a>
          )}

          {nextEntry ? (
            <a href={`/guide/${nextEntry.id}`} class="guide-nav-link guide-nav-next tbb-link">
              <span class="guide-nav-label">Next &rarr;</span>
              <span class="guide-nav-title">{chapterLabel(nextEntry)}: {nextEntry.data.title}</span>
            </a>
          ) : (
            <a href="/guide" class="guide-nav-link guide-nav-next tbb-link">
              <span class="guide-nav-label">Complete &rarr;</span>
              <span class="guide-nav-title">All Chapters</span>
            </a>
          )}
        </div>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .guide-header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--border-default);
  }

  .guide-chapter-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold-muted);
    margin-bottom: var(--space-3);
  }

  .guide-header h1 {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 300;
    color: var(--gold);
    margin-bottom: var(--space-3);
    letter-spacing: 0.5px;
  }

  .guide-description {
    font-size: 18px;
    font-weight: 400;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .guide-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── Chapter Sub-Chapter Navigation ── */
  .chapter-nav {
    border: 1px solid var(--border-default);
    background: var(--black-card);
    padding: var(--space-4) var(--space-5);
    margin: var(--space-3) 0 var(--space-5);
  }

  .chapter-nav-title {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold-muted);
    margin-bottom: var(--space-3);
    font-weight: 400;
  }

  .chapter-nav-title a {
    color: var(--gold-muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .chapter-nav-title a:hover {
    color: var(--gold);
  }

  .chapter-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .chapter-nav-list li {
    margin-bottom: var(--space-1);
  }

  .chapter-nav-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    font-size: 14px;
    font-weight: 300;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 4px 0;
    transition: color 0.3s ease;
  }

  a.chapter-nav-item:hover {
    color: var(--gold);
  }

  .chapter-nav-current .chapter-nav-item {
    color: var(--gold);
    font-weight: 400;
  }

  .chapter-nav-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--gold-muted);
    opacity: 0.5;
    min-width: 28px;
    flex-shrink: 0;
  }

  .chapter-nav-current .chapter-nav-num {
    opacity: 1;
    color: var(--gold);
  }

  /* ── Prev/Next Navigation ── */
  .guide-nav {
    padding: var(--space-6) 0;
  }

  .guide-nav-inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .guide-nav-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border-default);
    background: var(--black-card);
    text-decoration: none;
    transition: all 0.5s var(--ease-luxury);
    max-width: 48%;
  }

  .guide-nav-link:hover {
    border-color: var(--gold);
    background: rgba(255, 215, 0, 0.02);
  }

  .guide-nav-next {
    text-align: right;
    margin-left: auto;
  }

  .guide-nav-label {
    display: block;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-1);
    font-weight: 400;
  }

  .guide-nav-title {
    display: block;
    font-size: 15px;
    color: var(--text-primary);
    font-weight: 400;
    transition: color 0.3s ease;
  }

  .guide-nav-link:hover .guide-nav-title {
    color: var(--gold);
  }

  @media (max-width: 600px) {
    .guide-nav-inner {
      flex-direction: column;
    }

    .guide-nav-link {
      max-width: 100%;
    }

    .guide-nav-next {
      text-align: left;
    }
  }
</style>
